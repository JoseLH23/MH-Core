# Copia este archivo a .env y pon tus valores reales.
# .env NUNCA debe subirse a git (ya está en .gitignore).

# API key real requerida por TODAS las rutas de datos (CR-04,
# auditoría de seguridad 13/jul/2026) — sin esto configurado, el
# servidor rechaza todo por defecto (falla cerrado, no abierto).
# Genera una real con: python -c "import secrets; print(secrets.token_urlsafe(32))"
MH_CORE_API_KEY=

# Integración EjiXhole API v1 de solo lectura.
# URL base sin credenciales; el cliente agrega /api/v1 automáticamente.
EJIXHOLE_API_BASE_URL=http://localhost:8000
# Debe coincidir con MH_CORE_SERVICE_KEY del backend EjiXhole y ser distinta
# de MH_CORE_API_KEY. Nunca se guarda en Git.
EJIXHOLE_SERVICE_KEY=
EJIXHOLE_TIMEOUT_SECONDS=10

# Recepción de eventos de dominio enviados por el publicador de EjiXhole.
# Debe coincidir con MH_CORE_EVENT_SIGNING_SECRET del backend y ser distinta
# de todas las claves anteriores. Genera 48+ caracteres aleatorios.
EJIXHOLE_EVENT_SIGNING_SECRET=
# Ventana anti-replay permitida para la firma HMAC.
EJIXHOLE_EVENT_MAX_AGE_SECONDS=300
# Archivo SQLite durable. En servidor usa una ruta dentro de un volumen
# persistente; si se omite, usa mh_core/database/integrations/.
EJIXHOLE_EVENT_INBOX_PATH=

# Checkout local o volumen montado del repositorio privado MH-Knowledge.
# MH-Core no lo descarga automáticamente durante una petición: se exige
# una copia local versionada para evitar depender de red o texto remoto
# mutable. Ejemplo Windows: C:\MH-Knowledge
# Ejemplo Linux/contenedor: /app/MH-Knowledge
MH_KNOWLEDGE_PATH=

# YouTube Data API — usado por ResearchEngine/YouTubeResearchEngine
# para investigar tendencias reales. Sin esto, cae a un fallback
# honesto (tema fijo), nunca inventa datos. No es prioridad del nuevo
# enfoque de marketing privado para EjiXhole.
YOUTUBE_API_KEY=

# Gemini (Google AI Studio) — usado por generadores de contenido.
# Sin esto, cae al generador por plantillas, nunca rompe el pipeline.
GEMINI_API_KEY=
# Opcional — revisa disponibilidad antes de cambiar el modelo real.
GEMINI_MODEL=gemini-3.5-flash

# Groq — respaldo cuando Gemini falla o se agota su cuota.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

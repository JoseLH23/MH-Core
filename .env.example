# Copia este archivo a .env y pon tus valores reales.
# .env NUNCA debe subirse a git (ya está en .gitignore).

# API key real requerida por TODAS las rutas de datos (CR-04,
# auditoría de seguridad 13/jul/2026) — sin esto configurado, el
# servidor rechaza todo por defecto (falla cerrado, no abierto).
# Genera una real con: python -c "import secrets; print(secrets.token_urlsafe(32))"
MH_CORE_API_KEY=

# YouTube Data API — usado por ResearchEngine/YouTubeResearchEngine
# para investigar tendencias reales. Sin esto, cae a un fallback
# honesto (tema fijo), nunca inventa datos.
YOUTUBE_API_KEY=

# Gemini (Google AI Studio) — usado por GeminiContentGenerator para
# generar guiones/títulos reales. Sin esto, cae al generador por
# plantillas (apps/mindhigh/services/content_generator.py), nunca
# rompe el pipeline. Nivel gratis disponible sin tarjeta de crédito.
GEMINI_API_KEY=
# Opcional — modelo a usar. Por defecto: gemini-3.5-flash (nivel gratis).
GEMINI_MODEL=gemini-3.5-flash

# Groq — respaldo real cuando Gemini falla o se agota su cuota
# gratis (apps/mindhigh/services/ai_content_generator.py). Sin
# GROQ_API_KEY, simplemente se salta este paso y cae directo a
# plantillas — nunca rompe el pipeline.
GROQ_API_KEY=
# Opcional — modelo a usar. Por defecto: llama-3.3-70b-versatile (nivel gratis).
GROQ_MODEL=llama-3.3-70b-versatile

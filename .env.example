# Copia este archivo a .env y pon tus valores reales.
# .env NUNCA debe subirse a git (ya está en .gitignore).

# API key real requerida por TODAS las rutas de datos.
MH_CORE_API_KEY=

# Estado crítico de MH-Core: jobs y memoria. Vacío conserva SQLite local.
# En producción multiinstancia usa una URL PostgreSQL administrada.
MH_DATABASE_URL=
MH_DB_POOL_SIZE=5
MH_DB_MAX_OVERFLOW=5
MH_DB_POOL_TIMEOUT=30
MH_DB_POOL_RECYCLE=1800
MH_JOB_QUEUE=default
MH_JOB_LEASE_SECONDS=300
MH_JOB_POLL_SECONDS=2

# Integración EjiXhole API v1 de solo lectura.
EJIXHOLE_API_BASE_URL=http://localhost:8000
EJIXHOLE_SERVICE_KEY=
EJIXHOLE_TIMEOUT_SECONDS=10

# Recepción de eventos de dominio enviados por EjiXhole.
EJIXHOLE_EVENT_SIGNING_SECRET=
EJIXHOLE_EVENT_MAX_AGE_SECONDS=300
# Este canal permanece temporalmente en su bandeja SQLite actual.
EJIXHOLE_EVENT_INBOX_PATH=

# Checkout local o volumen montado del repositorio privado MH-Knowledge.
MH_KNOWLEDGE_PATH=

# Proveedores externos opcionales.
YOUTUBE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
